# TruthBench Environment Configuration
# Copy this file to .env and fill in your API keys

# Dataset
DATASET_PATH=datasets/sample_eval_dataset.json

# Evaluation
VERDICT_LABELS=SUPPORTED,CONTRADICTED,NOT_ENOUGH_EVIDENCE
RISK_LEVELS=LOW,MEDIUM,HIGH
CONFIDENCE_THRESHOLD=0.7

# Reporting
REPORT_OUTPUT_DIR=reports
REPORT_FORMAT=markdown

# Logging
LOG_LEVEL=INFO