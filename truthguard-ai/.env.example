# TruthGuardAI Environment Configuration
# Copy this file to .env and fill in your API keys

# Application
APP_NAME=TruthGuardAI
APP_VERSION=0.1.0
DEBUG=false

# LLM Provider Configuration
# Options: "mock", "openai", "anthropic"
LLM_PROVIDER=mock

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Search Provider Configuration
# Options: "mock", "tavily", "serpapi"
SEARCH_PROVIDER=mock

# Tavily (required if SEARCH_PROVIDER=tavily)
TAVILY_API_KEY=

# SerpAPI (required if SEARCH_PROVIDER=serpapi)
SERPAPI_API_KEY=

# Verification Settings
DEFAULT_TRUSTED_SOURCES=wikipedia,world-bank
MAX_CLAIMS_PER_ANSWER=20
EVIDENCE_PER_CLAIM=3